# ── Server ────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# The public URL of this Render backend (no trailing slash)
APP_BASE_URL=https://your-app.onrender.com

# The public URL of the Vercel frontend (no trailing slash)
FRONTEND_BASE_URL=https://your-app.vercel.app

# ── GoHighLevel App Credentials ───────────────────────────────────────────────
# From GHL Developer Portal > Your App > App Settings
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret

# GHL API base URL (do not change)
GHL_API_BASE=https://services.leadconnectorhq.com

# Pipeline and Stage IDs from the GHL Snapshot
# Copy these from GHL after importing the snapshot
GHL_PIPELINE_ID=your_pipeline_id
GHL_STAGE_ORDER_RECEIVED=your_stage_id_order_received
GHL_STAGE_SENT_TO_PRINT=your_stage_id_sent_to_print
GHL_STAGE_IN_PRODUCTION=your_stage_id_in_production
GHL_STAGE_SHIPPED=your_stage_id_shipped
GHL_STAGE_DELIVERED=your_stage_id_delivered
GHL_STAGE_FULFILLMENT_ISSUE=your_stage_id_fulfillment_issue

# GHL Custom Field IDs for Order Tracking (from the snapshot)
# These are the field IDs for the Contact custom fields
GHL_FIELD_LULU_PRINT_JOB_ID=your_field_id_lulu_print_job_id
GHL_FIELD_TRACKING_NUMBER=your_field_id_tracking_number
GHL_FIELD_FULFILLMENT_STATUS=your_field_id_fulfillment_status

# GHL Custom Field IDs for Book Data (numbered _1 through _10)
# These are written when a book is validated and ready
GHL_FIELD_BOOK_TITLE_PREFIX=book_title_
GHL_FIELD_POD_PACKAGE_PREFIX=pod_package_id_
GHL_FIELD_RETAIL_PRICE_PREFIX=retail_price_
GHL_FIELD_PRINT_COST_PREFIX=print_cost_
GHL_FIELD_AUTHOR_PROFIT_PREFIX=author_profit_

# ── Lulu API Credentials (Master Agency Account) ──────────────────────────────
# From https://developers.lulu.com > API Keys
LULU_CLIENT_ID=your_lulu_client_id
LULU_CLIENT_SECRET=your_lulu_client_secret

# Set to true to use Lulu sandbox for testing, false for production
LULU_SANDBOX=true

# Lulu webhook signing secret (set after registering the webhook)
LULU_WEBHOOK_SECRET=your_lulu_webhook_secret

# ── Supabase (Database + File Storage) ───────────────────────────────────────
# From Supabase Dashboard > Project Settings > API
# Use the service_role key (not the anon key) - required for server-side operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=book-pdfs

# ── Agency Billing ────────────────────────────────────────────────────────────
# Service fee charged to the sub-account wallet per print order (USD)
AGENCY_SERVICE_FEE_PER_ORDER=10.00
